{
  "name": "expo-todo-list",
  "version": "1.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "bump": "npm version patch --no-git-tag-version && node -e \"const fs=require('fs'); const pkg=require('./package.json'); const app=require('./app.json'); app.expo.version=pkg.version; fs.writeFileSync('./app.json', JSON.stringify(app, null, 2) + '\\n');\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^55.0.24",
    "expo-asset": "~55.0.17",
    "expo-constants": "~55.0.16",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-speech": "~55.0.14",
    "expo-sqlite": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "^5.3.3"
  },
  "private": true
}
